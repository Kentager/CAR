  10:USER/Src/main.c **** // To use uLog, you must define a function to process logging messages. It can
  11:USER/Src/main.c **** // write the messages to a console, to a file, to an in-memory buffer: the
  12:USER/Src/main.c **** // choice is yours.  And you get to choose the format of the message.
  13:USER/Src/main.c **** //
  14:USER/Src/main.c **** // The following example prints to the console.
  15:USER/Src/main.c **** //
  16:USER/Src/main.c **** // One caveat: msg is a static string and will be over-written at the next call
  17:USER/Src/main.c **** // to ULOG.  This means you may print it or copy it, but saving a pointer to it
  18:USER/Src/main.c **** // will lead to confusion and astonishment.
  19:USER/Src/main.c **** //
  20:USER/Src/main.c **** void my_console_logger(ulog_level_t severity, const char *msg) {
