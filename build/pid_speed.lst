 105:MyHardWare/Src/pid_speed.c ****  */
 106:MyHardWare/Src/pid_speed.c **** void Speed_PID_Update(Speed_PID_Controller_t *controller) {
 107:MyHardWare/Src/pid_speed.c ****   // هڈ‚و•°و£€وں¥
 108:MyHardWare/Src/pid_speed.c ****   if (controller == NULL || !controller->enabled) {
 109:MyHardWare/Src/pid_speed.c ****     return;
 110:MyHardWare/Src/pid_speed.c ****   }
 111:MyHardWare/Src/pid_speed.c **** 
 112:MyHardWare/Src/pid_speed.c ****   // è®،ç®—و—¶é—´é—´éڑ”ï¼ˆç§’ï¼‰
 113:MyHardWare/Src/pid_speed.c ****   uint32_t current_time = GetSysTick();
 114:MyHardWare/Src/pid_speed.c ****   float dt = (current_time - controller->last_update_time) / 1000.0f; // è½¬وچ¢ن¸؛ç§’
 115:MyHardWare/Src/pid_speed.c ****   
 116:MyHardWare/Src/pid_speed.c **** 
 117:MyHardWare/Src/pid_speed.c ****   // èژ·هڈ–ه½“ه‰چé€ںه؛¦
 118:MyHardWare/Src/pid_speed.c ****   controller->current_speed_m_s = get_encoder_speed_m_s(controller->encoder_id);
 119:MyHardWare/Src/pid_speed.c **** 
 120:MyHardWare/Src/pid_speed.c ****   // ن½؟ç”¨PIDç®—و³•è®،ç®—è¾“ه‡؛
 121:MyHardWare/Src/pid_speed.c ****   
 122:MyHardWare/Src/pid_speed.c ****   float error = controller->pid_state.target_value - controller->current_speed_m_s;//è®،ç®—è¯¯ه·®ه€
 123:MyHardWare/Src/pid_speed.c ****   float derivative = (error - controller->pid_state.last_error) / dt;//è®،ç®—ه¾®هˆ†é،¹
 124:MyHardWare/Src/pid_speed.c ****   float integral = (controller->pid_state.last_integral_error + error) * dt * 0.5f;//è®،ç®—ç§¯هˆ†é،
 125:MyHardWare/Src/pid_speed.c ****   float output = controller->pid_state.kp * error + controller->pid_state.ki *integral + controller
 126:MyHardWare/Src/pid_speed.c **** 
 127:MyHardWare/Src/pid_speed.c ****   // و›´و–°PIDçٹ¶و€پ
 128:MyHardWare/Src/pid_speed.c ****   controller->last_update_time = current_time; // و›´و–°و—¶é—´
 129:MyHardWare/Src/pid_speed.c ****   controller->pid_state.last_integral_error = integral;//و›´و–°ن¸ٹو¬،ç§¯هˆ†é،¹
 130:MyHardWare/Src/pid_speed.c ****   controller->pid_state.last_error = error;//و›´و–°ن¸ٹو¬،è¯¯ه·®é،¹
 131:MyHardWare/Src/pid_speed.c **** 
 132:MyHardWare/Src/pid_speed.c ****   // و›´و–°ç”µوœ؛è¾“ه‡؛
 133:MyHardWare/Src/pid_speed.c ****   update_motor_output(controller, output);
 134:MyHardWare/Src/pid_speed.c **** }
