 102:MyHardWare/Src/pid_speed.c **** /**
 103:MyHardWare/Src/pid_speed.c ****  * @brief 执行速度环PID控制计算
 104:MyHardWare/Src/pid_speed.c ****  * @param controller 控制器实例指针
 105:MyHardWare/Src/pid_speed.c ****  * @note 应在10ms控制循环中调用
 106:MyHardWare/Src/pid_speed.c ****  */
 107:MyHardWare/Src/pid_speed.c **** void Speed_PID_Update(Speed_PID_Controller_t *controller) {
 108:MyHardWare/Src/pid_speed.c ****   // 参数检查
 109:MyHardWare/Src/pid_speed.c ****   if (controller == NULL || !controller->enabled) {
 110:MyHardWare/Src/pid_speed.c ****     return;
 111:MyHardWare/Src/pid_speed.c ****   }
 112:MyHardWare/Src/pid_speed.c **** 
 113:MyHardWare/Src/pid_speed.c ****   // 计算时间间隔（秒）
 114:MyHardWare/Src/pid_speed.c ****   uint32_t current_time = GetSysTick();
 115:MyHardWare/Src/pid_speed.c ****   float dt =
 116:MyHardWare/Src/pid_speed.c ****       (current_time - controller->last_update_time) / 1000.0f; // 转换为秒
 117:MyHardWare/Src/pid_speed.c ****   controller->last_update_time = current_time;
 118:MyHardWare/Src/pid_speed.c **** 
 119:MyHardWare/Src/pid_speed.c ****   // 获取当前速度
 120:MyHardWare/Src/pid_speed.c ****   controller->current_speed_m_s = get_encoder_speed_m_s(controller->encoder_id);
 121:MyHardWare/Src/pid_speed.c **** 
 122:MyHardWare/Src/pid_speed.c ****   // 使用PID算法计算输出
 123:MyHardWare/Src/pid_speed.c ****   float output =
 124:MyHardWare/Src/pid_speed.c ****       pid_realize(&controller->pid_state, controller->current_speed_m_s);
 125:MyHardWare/Src/pid_speed.c **** 
 126:MyHardWare/Src/pid_speed.c ****   // 更新电机输出
 127:MyHardWare/Src/pid_speed.c ****   update_motor_output(controller, output);
 128:MyHardWare/Src/pid_speed.c **** }
