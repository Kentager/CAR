 145:MyHardWare/Src/pid_speed.c **** /**
 146:MyHardWare/Src/pid_speed.c ****  * @brief 更新电机输出
 147:MyHardWare/Src/pid_speed.c ****  * @param controller 控制器实例指针
 148:MyHardWare/Src/pid_speed.c ****  * @param output PID输出值
 149:MyHardWare/Src/pid_speed.c ****  */
 150:MyHardWare/Src/pid_speed.c **** static void update_motor_output(Speed_PID_Controller_t *controller,
 151:MyHardWare/Src/pid_speed.c ****                                 float output) {
 152:MyHardWare/Src/pid_speed.c ****   // 限制输出范围
 153:MyHardWare/Src/pid_speed.c ****   if (output > SPEED_PID_OUTPUT_MAX) {
 154:MyHardWare/Src/pid_speed.c ****     output = SPEED_PID_OUTPUT_MAX;
 155:MyHardWare/Src/pid_speed.c ****   } else if (output < -SPEED_PID_OUTPUT_MAX) {
 156:MyHardWare/Src/pid_speed.c ****     output = -SPEED_PID_OUTPUT_MAX;
 157:MyHardWare/Src/pid_speed.c ****   }
 158:MyHardWare/Src/pid_speed.c **** 
 159:MyHardWare/Src/pid_speed.c ****   // 根据输出符号确定方向
 160:MyHardWare/Src/pid_speed.c ****   Motor_Direction_e direction;
 161:MyHardWare/Src/pid_speed.c ****   if (output > 100) { // 死区设置
 162:MyHardWare/Src/pid_speed.c ****     direction = MOTOR_DIR_FORWARD;
 163:MyHardWare/Src/pid_speed.c ****   } else if (output < -100) {
 164:MyHardWare/Src/pid_speed.c ****     direction = MOTOR_DIR_BACKWARD;
 165:MyHardWare/Src/pid_speed.c ****   } else {
 166:MyHardWare/Src/pid_speed.c ****     direction = MOTOR_DIR_STOP;
 167:MyHardWare/Src/pid_speed.c ****     output = 0; // 停止时输出为0
 168:MyHardWare/Src/pid_speed.c ****   }
 169:MyHardWare/Src/pid_speed.c **** 
 170:MyHardWare/Src/pid_speed.c ****   // 设置电机方向和速度
 171:MyHardWare/Src/pid_speed.c ****   Motor_SetDirection(controller->motor_id, direction);
 172:MyHardWare/Src/pid_speed.c ****   Motor_SetSpeed(controller->motor_id, (int16_t)output);
 173:MyHardWare/Src/pid_speed.c **** 
 174:MyHardWare/Src/pid_speed.c ****   // 更新硬件
 175:MyHardWare/Src/pid_speed.c ****   Motor_Update(controller->motor_id);
 176:MyHardWare/Src/pid_speed.c **** }
 177:MyHardWare/Src/pid_speed.c **** 
