 132:MyHardWare/Src/pid_speed.c **** /**
 133:MyHardWare/Src/pid_speed.c ****  * @brief 获取编码器测量的速度 (m/s)
 134:MyHardWare/Src/pid_speed.c ****  * @param encoder_id 编码器ID
 135:MyHardWare/Src/pid_speed.c ****  * @return 当前线速度 (m/s)
 136:MyHardWare/Src/pid_speed.c ****  */
 137:MyHardWare/Src/pid_speed.c **** static float get_encoder_speed_m_s(Encoder_Id_e encoder_id) {
 138:MyHardWare/Src/pid_speed.c ****   // 获取编码器数据
 139:MyHardWare/Src/pid_speed.c ****   Encoder_Data_t encoder_data = Encoder_GetData(encoder_id);
 140:MyHardWare/Src/pid_speed.c **** 
 141:MyHardWare/Src/pid_speed.c ****   // 返回线速度
 142:MyHardWare/Src/pid_speed.c ****   return encoder_data.speed_m_s;
 143:MyHardWare/Src/pid_speed.c **** }
