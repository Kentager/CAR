 156:MyHardWare/Src/pid_speed.c **** static void update_motor_output(Speed_PID_Controller_t *controller,
 157:MyHardWare/Src/pid_speed.c ****                                 float output) {
 158:MyHardWare/Src/pid_speed.c ****   // é™گهˆ¶è¾“ه‡؛èŒƒه›´
 159:MyHardWare/Src/pid_speed.c ****   if (output > SPEED_PID_OUTPUT_MAX) {
 160:MyHardWare/Src/pid_speed.c ****     output = SPEED_PID_OUTPUT_MAX;
 161:MyHardWare/Src/pid_speed.c ****   } else if (output < -SPEED_PID_OUTPUT_MAX) {
 162:MyHardWare/Src/pid_speed.c ****     output = -SPEED_PID_OUTPUT_MAX;
 163:MyHardWare/Src/pid_speed.c ****   }
 164:MyHardWare/Src/pid_speed.c **** 
 165:MyHardWare/Src/pid_speed.c ****   // و ¹وچ®è¾“ه‡؛ç¬¦هڈ·ç،®ه®ڑو–¹هگ‘
 166:MyHardWare/Src/pid_speed.c ****   Motor_Direction_e direction;
 167:MyHardWare/Src/pid_speed.c ****   if (output > 100) { // و­»هŒ؛è®¾ç½®
 168:MyHardWare/Src/pid_speed.c ****     direction = MOTOR_DIR_FORWARD;
 169:MyHardWare/Src/pid_speed.c ****   } else if (output < -100) {
 170:MyHardWare/Src/pid_speed.c ****     direction = MOTOR_DIR_BACKWARD;
 171:MyHardWare/Src/pid_speed.c ****   } else {
 172:MyHardWare/Src/pid_speed.c ****     direction = MOTOR_DIR_STOP;
 173:MyHardWare/Src/pid_speed.c ****     output = 0; // هپœو­¢و—¶è¾“ه‡؛ن¸؛0
 174:MyHardWare/Src/pid_speed.c ****   }
 175:MyHardWare/Src/pid_speed.c **** 
 176:MyHardWare/Src/pid_speed.c ****   // è®¾ç½®ç”µوœ؛و–¹هگ‘ه’Œé€ںه؛¦
 177:MyHardWare/Src/pid_speed.c ****   Motor_SetDirection(controller->motor_id, direction);
 178:MyHardWare/Src/pid_speed.c ****   Motor_SetSpeed(controller->motor_id, (int16_t)output);
 179:MyHardWare/Src/pid_speed.c **** 
 180:MyHardWare/Src/pid_speed.c ****   // و›´و–°ç،¬ن»¶
 181:MyHardWare/Src/pid_speed.c ****   Motor_Update(controller->motor_id);
 182:MyHardWare/Src/pid_speed.c **** }
