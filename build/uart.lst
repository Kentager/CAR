 102:MyHardWare/Src/uart.c **** /**
 103:MyHardWare/Src/uart.c ****  * @brief  UART1发送数据数组
 104:MyHardWare/Src/uart.c ****  * @param  data: 要发送的数据数组
 105:MyHardWare/Src/uart.c ****  * @param  size: 数据大小
 106:MyHardWare/Src/uart.c ****  * @retval None
 107:MyHardWare/Src/uart.c ****  */
 108:MyHardWare/Src/uart.c **** void UART1_SendData(uint16_t *data, uint16_t size) {
 109:MyHardWare/Src/uart.c ****   uint16_t i, j;
 110:MyHardWare/Src/uart.c ****   char temp_str[16];
 111:MyHardWare/Src/uart.c **** 
 112:MyHardWare/Src/uart.c ****   for (i = 0; i * 10 < size; i++) {
 113:MyHardWare/Src/uart.c **** 
 114:MyHardWare/Src/uart.c ****     for (j = 0; (i * 10 + j) < size; i++) {
 115:MyHardWare/Src/uart.c ****       /* 将16位数据转换为字符串 */
 116:MyHardWare/Src/uart.c ****       Int16ToString(data[i * 10 + j], temp_str);
 117:MyHardWare/Src/uart.c ****       UART1_SendString(temp_str);
 118:MyHardWare/Src/uart.c ****       UART1_SendString(" ");
 119:MyHardWare/Src/uart.c **** 
 120:MyHardWare/Src/uart.c ****       /* 添加小延时避免发送过快 */
 121:MyHardWare/Src/uart.c ****       /* 可以根据需要调整延时 */
 122:MyHardWare/Src/uart.c ****     }
 123:MyHardWare/Src/uart.c ****     UART1_SendString("\r\n");
 124:MyHardWare/Src/uart.c ****   }
 125:MyHardWare/Src/uart.c **** }
